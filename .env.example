# =============================================================================
# SECURITY BEST PRACTICES
# =============================================================================
# 1. NEVER commit this .env file to version control (add to .gitignore)
# 2. Use different secrets for dev/staging/production environments
# 3. Rotate all secrets every 90 days in production
# 4. Use a secrets manager (AWS Secrets Manager, HashiCorp Vault) in production
# 5. All passwords should be minimum 16 characters with letters+digits+specials
# 6. Enable HTTPS for all API endpoints in production
# 7. Configure rate limiting on Nginx level
# 8. Monitor logs for security anomalies
# =============================================================================

# PostgreSQL Configuration
# SECURITY: Use strong password (min 16 chars, letters+digits+specials)
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(24))'
POSTGRES_USER=ssn_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=ssn_users
DATABASE_URL=postgresql+asyncpg://ssn_user:change_me_strong_password@postgres:5432/ssn_users

# SQLite Configuration
SQLITE_PATH=/app/data/ssn_database.db

# JWT Configuration
# SECURITY: JWT_SECRET must be cryptographically strong (min 32 chars)
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
# IMPORTANT: Rotate this secret every 90 days in production
JWT_SECRET=change_me_long_random_string_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Webhook Configuration
# Webhook secret for signature verification (HMAC-SHA256)
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
# Leave empty to disable signature verification (not recommended for production)
WEBHOOK_SECRET=change_me_webhook_secret_min_32_chars

# CORS Configuration (for Public API)
# Production: https://huntrssn.cc,https://www.huntrssn.cc
ALLOWED_ORIGINS=*
ORIGIN=http://localhost

# Admin CORS Configuration
# Production: https://infinitymoneyyy.xyz,https://www.infinitymoneyyy.xyz
ALLOWED_ORIGINS_ADMIN=*

# SearchBug API Configuration
# SearchBug company code for data enrichment
SEARCHBUG_CO_CODE=your_searchbug_company_code

# SearchBug API password
SEARCHBUG_PASSWORD=your_searchbug_password

# SearchBug API base URL
SEARCHBUG_API_URL=https://data.searchbug.com/api/search.aspx

# SearchBug API Configuration
# Default limit for search results
SEARCHBUG_DEFAULT_LIMIT=100

# Cryptocurrency API Configuration
CRYPTOCURRENCYAPI_KEY=your_cryptocurrencyapi_key
IPN_WEBHOOK_URL=http://localhost/api/public/billing/ipn/cryptocurrencyapi

# Helket Payment Gateway Configuration
HELKET_API_KEY=your_helket_api_key
HELKET_MERCHANT_UUID=your_merchant_uuid
HELKET_WEBHOOK_SECRET=your_webhook_secret
HELKET_API_URL=https://api.heleket.com
HELKET_IPN_WEBHOOK_URL=http://localhost/api/public/billing/ipn/helket

# ff.io (FixedFloat) Payment Gateway Configuration
FFIO_API_KEY=your_ffio_api_key
FFIO_API_SECRET=your_ffio_api_secret
FFIO_API_URL=https://ff.io
# ff.io does not support webhooks, status is checked via polling
# Optional: Platform receiving address for ff.io orders
FFIO_PLATFORM_ADDRESS=

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Use DEBUG for development, INFO for staging, WARNING for production
LOG_LEVEL=INFO

# Enable JSON structured logging (recommended for production)
# Set to 'true' for JSON format, 'false' for human-readable format
# JSON format is required for log aggregation tools (ELK, Loki, CloudWatch)
LOG_JSON_ENABLED=true

# Performance metrics logging
# Log slow requests (requests taking longer than threshold)
LOG_SLOW_REQUEST_THRESHOLD_MS=1000

# Correlation ID header name (for distributed tracing)
# Default: X-Request-ID
CORRELATION_ID_HEADER=X-Request-ID

# Redis Configuration (для distributed rate limiting)
# URL для подключения к Redis
REDIS_URL=redis://redis:6379/0

# Database Pool Configuration
# Увеличенные значения для предотвращения исчерпания пула соединений при высокой нагрузке
# pool_size: базовый размер пула соединений (постоянно открытых)
DB_POOL_SIZE=30
# max_overflow: дополнительные соединения сверх pool_size (временные)
DB_MAX_OVERFLOW=20
# pool_timeout: максимальное время ожидания свободного соединения (секунды)
DB_POOL_TIMEOUT=30
# pool_recycle: время переиспользования соединения (секунды, 1800 = 30 минут)
DB_POOL_RECYCLE=1800
# pool_pre_ping: проверка соединения перед использованием (предотвращает "мертвые" соединения)
# Допустимые значения: true/1/yes/on (включено), false/0/no/off (выключено), регистр не важен
DB_POOL_PRE_PING=true

# Production рекомендации:
# - Убедитесь что PostgreSQL max_connections > (workers * pool_size) + max_overflow для всех API
# - Расчёт для production значений (DB_POOL_SIZE=40, DB_MAX_OVERFLOW=30):
#   * Public API: (4 workers * 40) + 30 = 190 соединений
#   * Admin API: (2 workers * 40) + 30 = 110 соединений
#   * Итого: 300 соединений (установлено в docker-compose.production.yml)
# - Для dev режима с текущими значениями (30/20):
#   * Public API: (4 * 30) + 20 = 140
#   * Admin API: (2 * 30) + 20 = 80
#   * Итого: минимум 220 соединений

# Uvicorn Workers Configuration
# Количество worker процессов для обработки запросов
# Рекомендация: CPU cores * 2 для I/O bound приложений
UVICORN_WORKERS=4
UVICORN_WORKERS_ADMIN=2
UVICORN_WORKERS_LOOKUP=2

# Invitation/Referral Bonus Configuration
# Бонус для нового пользователя при регистрации с кодом приглашения
INVITATION_BONUS_INVITEE=5.00
# Бонус для пользователя, который пригласил нового пользователя
INVITATION_BONUS_INVITER=3.00

# Telegram Bot Configuration
# Получите токен от @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# API ключ для аутентификации бота на WebSocket endpoint
# Сгенерируйте случайный ключ (минимум 32 символа):
# python -c 'import secrets; print(secrets.token_hex(32))'
BOT_API_KEY=change_me_bot_api_key_min_32_chars

# WebSocket Configuration (optional, defaults provided)
# Начальная задержка переподключения WebSocket в секундах
WS_RECONNECT_DELAY=5
# Максимальная задержка переподключения в секундах (5 минут)
WS_MAX_RECONNECT_DELAY=300
# Интервал heartbeat для WebSocket в секундах
WS_HEARTBEAT_INTERVAL=30

# =============================================================================
# TELEGRAM ALERTING CONFIGURATION
# =============================================================================
# Telegram Bot Token for sending critical alerts to admin channel
# Get token from @BotFather in Telegram (separate bot for alerts recommended)
# Generate with: Create new bot via @BotFather, copy token
# Leave empty to disable Telegram alerting
TELEGRAM_ALERT_BOT_TOKEN=

# Telegram Channel/Chat ID where alerts will be sent
# For channels: Use @username or numeric ID (e.g., -1001234567890)
# For private chats: Use numeric user ID
# To get chat ID: Send message to bot, then call getUpdates API
# Leave empty to disable Telegram alerting
TELEGRAM_ALERT_CHANNEL_ID=

# Alert types that will be sent to Telegram:
# - Critical: DB failures, high error rate (>10%), service crashes
# - Warning: Multiple 500 errors (>5/min), rate limit abuse (>100/user)
# - Info: Service startup/shutdown
# Note: Alerts are rate-limited to max 1 per minute per event type

# =============================================================================
# SECURITY VALIDATION SETTINGS
# =============================================================================
# Maximum string length for user inputs (protection against DoS)
MAX_STRING_LENGTH=1000
# Maximum nesting depth for JSON metadata
MAX_METADATA_DEPTH=5
# Maximum size of metadata in bytes
MAX_METADATA_SIZE=10000
# Enable strict input validation (recommended for production)
ENABLE_STRICT_VALIDATION=true

# Instructions:
# 1. Copy this file to .env
# 2. Change all passwords and secrets to strong, random values
# 3. Update ENRICHMENT_API_KEYS with your actual API keys
# 4. Generate WEBHOOK_SECRET for webhook signature verification
# 5. Add your TELEGRAM_BOT_TOKEN from @BotFather
# 6. Generate BOT_API_KEY for bot authentication
# 7. Adjust ALLOWED_ORIGINS for your frontend URLs
# 8. Add your CRYPTOCURRENCYAPI_KEY from cryptocurrencyapi.net dashboard
# 9. Add your HELKET_API_KEY and HELKET_MERCHANT_UUID from Helket dashboard
# 10. Add your FFIO_API_KEY and FFIO_API_SECRET from ff.io dashboard
# 11. Update HELKET_IPN_WEBHOOK_URL with your production domain
# 12. NEVER commit .env to version control
# 13. Review docs/SECURITY.md for complete security guidelines
# 14. Configure logging for your environment:
#     - Development: LOG_LEVEL=DEBUG, LOG_JSON_ENABLED=false
#     - Staging: LOG_LEVEL=INFO, LOG_JSON_ENABLED=true
#     - Production: LOG_LEVEL=WARNING, LOG_JSON_ENABLED=true
# 15. For production, consider using centralized logging (ELK, Loki)
#     See docs/LOGGING.md for setup instructions
# 16. Configure Telegram alerting (optional but recommended for production):
#     - Create separate bot via @BotFather for alerts
#     - Add bot to your admin channel/group as administrator
#     - Set TELEGRAM_ALERT_BOT_TOKEN and TELEGRAM_ALERT_CHANNEL_ID
#     - Test with service restart to receive startup alert

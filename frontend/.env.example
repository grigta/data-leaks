# Public API URLs
# For SvelteKit, environment variables that should be accessible in the browser must be prefixed with PUBLIC_

# Development configuration (using Vite proxy)
PUBLIC_API_URL=/api/public
PUBLIC_ENRICHMENT_API_URL=/api/enrichment

# Production configuration
# In production, use relative URLs - nginx will handle routing
# PUBLIC_API_URL=/api/public
# PUBLIC_ENRICHMENT_API_URL=/api/enrichment

# Note: Copy this file to .env for local development
# Never commit .env to version control
